# ============================================================
# nd-bot-v2 environment. Copy to .env and fill in. NEVER commit .env.
# ============================================================

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
# Optional: register slash commands to one guild for instant updates during dev
SLASH_COMMANDS_GUILD_ID=

# --- AI providers (multi-provider: Gemini + Claude) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Default provider routing: auto | gemini | claude
AI_PROVIDER_MODE=auto
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-opus-4-8

# --- Database (SQLite + Drizzle) ---
DATABASE_PATH=./data/nd-bot-v2.sqlite

# --- Dashboard API + auth ---
# Bound loopback by default; NGINX reverse-proxies the public domain.
# API_PORT must match the proxy_pass port in deploy/nginx/botv2.nightz.dev.conf.
# 4010 (not 4000) since a shared VPS may already run another app on 4000.
API_HOST=127.0.0.1
API_PORT=4010
DASHBOARD_PUBLIC_URL=https://botv2.nightz.dev
# Discord OAuth redirect for this dashboard: https://botv2.nightz.dev/api/auth/callback
# Add that exact URL to the Discord app's OAuth2 redirects.
# Strong random secret (>=32 chars). Generate: openssl rand -hex 32
DASHBOARD_JWT_SECRET=
# Discord OAuth for dashboard login
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
# Admin gating: comma-separated Discord user IDs and/or role IDs
DASHBOARD_ADMIN_USER_IDS=
DASHBOARD_ADMIN_ROLE_IDS=

# --- Runtime ---
NODE_ENV=production
LOG_LEVEL=info
DEFAULT_LOCALE=en
